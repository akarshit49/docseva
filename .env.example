# ── Infrastructure ────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=docseva
POSTGRES_USER=docseva
POSTGRES_PASSWORD=docseva_secret_change_in_prod

REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
# Public address used in presigned download URLs. Must be reachable from users' devices.
# Local dev: your machine's LAN IP (e.g. 192.168.1.10:9000)
# Production: your public MinIO domain (e.g. files.docseva.in)
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret_change_in_prod
MINIO_BUCKET_UPLOADS=docseva-uploads
MINIO_BUCKET_OUTPUTS=docseva-outputs
MINIO_BUCKET_ASSETS=docseva-assets
MINIO_USE_SSL=false

# ── API Service ────────────────────────────────────────────────────────────────
API_BASE_URL=http://api:8000
API_SECRET_KEY=change_this_to_a_long_random_string_in_production
API_BOT_TOKEN=internal_bot_api_token_change_in_prod

# ── Bot Service ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Used to build channel-link deep links like https://t.me/<username>?start=link_<token>.
TELEGRAM_BOT_USERNAME=docseva_bot
# Public WhatsApp number (E.164, digits only) used in wa.me deep links.
WHATSAPP_NUMBER_E164=

# ── WhatsApp adapter (Sprint 5 / WS-E) ────────────────────────────────────────
# Provider: 'mock' for local dev, 'wati' for launch, 'gupshup' for failover.
WA_BSP_PROVIDER=mock

# WATI
WA_WATI_API_BASE=https://app-server.wati.io/api/v1
WA_WATI_API_TOKEN=
# Static verify token configured in the WATI console (matches Authorization header).
WA_WATI_VERIFY_TOKEN=

# Gupshup
WA_GUPSHUP_API_BASE=https://api.gupshup.io/sm/api/v1
WA_GUPSHUP_API_KEY=
WA_GUPSHUP_SOURCE_NUMBER=
WA_GUPSHUP_APP_NAME=

# Shared with the API
WA_API_BOT_TOKEN=internal_bot_api_token_change_in_prod
WA_WHATSAPP_NUMBER_E164=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Email delivery (Sprint 1 / WS-A) ──────────────────────────────────────────
# 'log' (default), 'resend', or 'sendgrid'. 'log' just prints OTPs to the API logs
# which is perfect for development and CI.
EMAIL_PROVIDER=log
EMAIL_FROM=DocSeva <noreply@docseva.in>
# RESEND_API_KEY=
# SENDGRID_API_KEY=

# ── Feature limits (per plan) ─────────────────────────────────────────────────
FREE_PLAN_DOCS_PER_MONTH=10
STARTER_PLAN_DOCS_PER_MONTH=100
PRO_PLAN_DOCS_PER_MONTH=500
BUSINESS_PLAN_DOCS_PER_MONTH=99999

# ── Storage ───────────────────────────────────────────────────────────────────
# Presigned URL expiry in seconds (24 h default)
PRESIGNED_URL_EXPIRY=86400
# Auto-delete documents after N days
DOCUMENT_RETENTION_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
