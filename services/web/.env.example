# #genai: Sprint 3 — Next.js web env. Copy to .env.local for local dev.

# Server-side base URL used by route handlers + server components.
# In docker-compose this is the in-cluster name; locally point at localhost.
API_INTERNAL_URL=http://localhost:8000

# Client-side base URL (exposed to the browser). Only used for media URLs
# that the browser must fetch directly. API calls go through Next's proxy.
NEXT_PUBLIC_API_BASE_URL=

# Cookie secret used to sign the session cookie. Generate a long random
# string in production.
WEB_COOKIE_SECRET=change_this_to_a_long_random_string_in_production

# Cookie name (rarely needs changing).
WEB_SESSION_COOKIE=docseva_session
